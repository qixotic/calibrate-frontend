{
  "name": "calibrate-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prepare": "husky",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test --project=public",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:coverage": "E2E_COVERAGE=1 playwright test --project=public && node scripts/clean-e2e-lcov.mjs",
    "coverage": "npm run test:coverage && npm run test:e2e:coverage",
    "test:e2e:integration": "scripts/e2e-fake-backend.sh npm run test:e2e:authenticated",
    "test:e2e:integration:coverage": "scripts/e2e-fake-backend.sh npm run test:e2e:authenticated:coverage",
    "test:e2e:authenticated": "playwright test --project=authenticated --workers=1",
    "test:e2e:authenticated:coverage": "E2E_COVERAGE=1 playwright test --project=authenticated --workers=1 && node scripts/clean-e2e-lcov.mjs"
  },
  "dependencies": {
    "@next/third-parties": "^16.1.4",
    "@sentry/nextjs": "^10.36.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jszip": "^3.4.0",
    "@vercel/analytics": "^1.6.1",
    "canvas-confetti": "^1.9.4",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "next": "16.1.1",
    "next-auth": "^5.0.0-beta.30",
    "papaparse": "^5.5.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "husky": "^9.1.7",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "monocart-reporter": "^2.12.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
